APP_NAME=CheckPriceCS2
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=checkpricecs2
DB_USERNAME=root
DB_PASSWORD=123456

# VPS: user checkpricecs2 — chạy bash deploy/configure-mysql.sh trên server

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

STEAM_API_KEY=
BUFF163_SESSION=
BUFF163_CSRF_TOKEN=

CNY_TO_VND=3750
# Giá đã có: tra lại sau 2h. Mỗi 10p scheduler sync (ưu tiên chưa có giá + giá > 2h).
BUFF_PRICE_REFRESH_SECONDS=7200
BUFF_PRICE_AUTO_SYNC=true
BUFF_PRICE_AUTO_SYNC_MINUTES=10
BUFF_REQUEST_DELAY_MS=350
BUFF_CONCURRENCY=2
CHECK_MAX_EXECUTION_SECONDS=600
STEAM_INVENTORY_PAGE_SIZE=2000

# Lịch sử giá admin (VN timezone)
BUFF_PRICE_CURRENT_WINDOW_HOURS=2
PRICE_HISTORY_DAYS=90
PRICE_HISTORY_MAX_POINTS=3000
