APP_NAME=CheckPriceCS2
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

# SEO / chia sẻ (Facebook, Zalo, Instagram, X, Google)
SITE_NAME=CheckPrice CS2
SITE_TITLE=CheckPrice CS2 — Tra giá kho CS2 theo Buff163
SITE_DESCRIPTION=Xem giá trị kho đồ CS2 theo Buff163, quy đổi VND/USD, skin đang trade hold và lịch sử giá.
SITE_KEYWORDS=CS2, giá skin CS2, Buff163, inventory CS2, giá kho CS2, Steam
SITE_OG_IMAGE=/images/og-share.jpg
SITE_OG_IMAGE_WIDTH=1200
SITE_OG_IMAGE_HEIGHT=630
SITE_LOCALE=vi_VN
SITE_ROBOTS=index, follow
SITE_THEME_COLOR=#0d1117
SITE_AUTHOR=Nguyễn Tuấn Hùng
# SITE_TWITTER=@your_handle
# FACEBOOK_APP_ID=
# GOOGLE_SITE_VERIFICATION=mã_từ_search_console

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=checkpricecs2
DB_USERNAME=root
DB_PASSWORD=123456

# VPS: user checkpricecs2 — chạy bash deploy/configure-mysql.sh trên server

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Kho: cs.trade trước, lỗi thì Steam. Chỉ Steam: INVENTORY_SOURCE=steam
INVENTORY_SOURCE=cstrade
INVENTORY_FALLBACK_STEAM=true
CSTRADE_PROBE_STEAM_ID=76561198959660892

STEAM_API_KEY=
BUFF163_SESSION=
BUFF163_CSRF_TOKEN=

# CSGOEmpire — so sánh giá withdraw market (cần API key tại csgoempire.com → Developer)
EMPIRE_ENABLED=false
# Key Empire: quản lý trong Admin → Buff & cs.trade (sau migrate). .env chỉ dùng lần import đầu.
CSGOEMPIRE_API_KEY=
EMPIRE_BULK_PARALLEL=true
# 1 coin ≈ USD (mặc định 0.614 — chỉnh nếu cần)
EMPIRE_COIN_TO_USD=0.6143
EMPIRE_PRICE_REFRESH_SECONDS=14400
EMPIRE_SEARCH_DELAY_MS=3500
EMPIRE_MAX_FETCHES_PER_CHECK=15
EMPIRE_MAX_FETCHES_PER_SYNC=0
# paginate = nhanh (quét trang), search = chậm, auto = paginate + search phần thiếu
EMPIRE_FETCH_MODE=auto
EMPIRE_BULK_CACHE_SECONDS=600
EMPIRE_BULK_MAX_PAGES=25
# Giới hạn trang Empire khi bấm ⟳ admin (tránh timeout nginx)
EMPIRE_HTTP_MAX_PAGES=12
# ⟳ admin: 0 = mỗi key ~10 lần search (5 key ≈ 50 skin)
EMPIRE_HTTP_MAX_SEARCHES=0
EMPIRE_HTTP_MAX_SEARCHES_PER_KEY=10
EMPIRE_PAGE_DELAY_MS=550
# Acc Buff dự phòng (acc 2, 3...) — tự chuyển khi acc trước bị 429/403
# BUFF163_SESSION_2=
# BUFF163_CSRF_TOKEN_2=
# BUFF163_SESSION_3=
# BUFF163_CSRF_TOKEN_3=

CNY_TO_VND=3750
VND_TO_USD=26700
# Empire: 1 coin ≈ 0.6143 USD → ~16402 ₫ (100 coin ≈ 1.640.181 ₫); sửa trong admin
EMPIRE_COIN_TO_VND=16401.81
# Tự sync: quét kho Steam + giá Buff mỗi 4h. Giá Buff cache cùng chu kỳ 4h.
BUFF_PRICE_REFRESH_SECONDS=14400
BUFF_PRICE_AUTO_SYNC=true
BUFF_PRICE_AUTO_SYNC_MINUTES=240
BUFF_REQUEST_DELAY_MS=800
BUFF_CONCURRENCY=1
CHECK_MAX_EXECUTION_SECONDS=600
# 300 = 5 phút — mỗi IP chỉ tra 1 kho trên trang chủ
GUEST_CHECK_COOLDOWN_SECONDS=300
STEAM_INVENTORY_PAGE_SIZE=2000
STEAM_REQUEST_DELAY_MS=1500
# 1200000 = 20 phút giữa mỗi kho khi phải gọi Steam
STEAM_REQUEST_DELAY_BETWEEN_INVENTORIES_MS=1200000
# 86400 = 24h — cron tự động không quét lại Steam mỗi lần
STEAM_INVENTORY_CACHE_SECONDS=86400

# Lịch sử giá admin (VN timezone)
BUFF_PRICE_CURRENT_WINDOW_HOURS=2
PRICE_HISTORY_DAYS=90
PRICE_HISTORY_MAX_POINTS=3000
